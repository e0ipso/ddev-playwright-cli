#!/usr/bin/env bash
#ddev-generated

SOURCE=".ddev/web-build/disabled.Dockerfile.playwright-cli"
if [[ ! -f "$SOURCE" ]]; then
  echo "Error: $SOURCE not found. Run 'ddev add-on get e0ipso/ddev-playwright-cli' first."
  exit 1
fi

echo "Rebuilding web service with Playwright CLI..."
cp "$SOURCE" .ddev/web-build/Dockerfile.playwright-cli
ddev restart
